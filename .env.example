# API
ASPNETCORE_ENVIRONMENT=Development
PORT=8080
POSTGRES_DB=medsync
POSTGRES_USER=medsync
POSTGRES_PASSWORD=replace_with_a_local_password
DATABASE_URL=postgresql://medsync:replace_with_a_local_password@localhost:5432/medsync
REDIS_URL=redis://localhost:6379
JWT_SECRET=generate_a_random_secret_with_at_least_32_characters
JWT_ISSUER=MedSync
JWT_AUDIENCE=MedSync.Web
SEED_DEMO_PASSWORD=choose_a_local_demo_password
FRONTEND_URL=http://localhost:3000
PUBLIC_APP_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:8080
AUTH_COOKIE_SAMESITE=Lax
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=replace_with_your_livekit_api_key
LIVEKIT_API_SECRET=replace_with_your_livekit_api_secret
VIDEO_E2EE_SECRET=generate_an_independent_random_secret_with_at_least_32_characters
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# Web (configure these in apps/web/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
